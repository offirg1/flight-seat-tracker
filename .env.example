# Copy to .env for local runs (never commit .env)

# Duffel (default provider) — create a token at app.duffel.com
DUFFEL_API_TOKEN=your_duffel_access_token

# Legacy Amadeus provider (self-service portal shut down 2026-07-17)
# PROVIDER=amadeus
# AMADEUS_API_KEY=your_api_key
# AMADEUS_API_SECRET=your_api_secret
# AMADEUS_ENV=test
